{
  "$schema": "https://graphite.dev/schemas/verification-result-v1.json",
  "type": "object",
  "required": ["confidence", "breakdown", "trust_tier", "risk_verdict", "audit_trail_id"],
  "properties": {
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "breakdown": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "raw_value", "weight", "contribution"],
        "properties": {
          "kind": { "type": "string" },
          "raw_value": { "type": "number" },
          "weight": { "type": "number" },
          "contribution": { "type": "number" }
        }
      }
    },
    "trust_tier": {
      "type": "string",
      "enum": ["Unknown", "HeuristicInferred", "OfficialManifest", "SimulationValidated", "CommunityVerified", "BattleTested"]
    },
    "risk_verdict": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["Clear", "Blocked"] },
        "findings": { "type": "array", "items": { "type": "object" } }
      }
    },
    "policy_verdict": { "type": ["string", "null"] },
    "audit_trail_id": { "type": "string" }
  }
}
